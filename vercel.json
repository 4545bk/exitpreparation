{
  "version": 2,
  "builds": [
    {
      "src": "exam-app/backend/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "exam-app/frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "exam-app/backend/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "exam-app/frontend/$1"
    }
  ]
}
